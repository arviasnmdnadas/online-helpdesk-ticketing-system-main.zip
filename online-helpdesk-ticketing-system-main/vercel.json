{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/**/*",
      "use": "@vercel/static"
    }
  ],
  
  
  "routes": [
    {
  "src": "/swagger.json",
  "dest": "/api/index.js"
},

  {
    "src": "/api-docs/(.*)",
    "dest": "/api/index.js"
  },
  {
    "src": "/api-docs",
    "dest": "/api/index.js"
  },
  {
    "src": "/api/(.*)",
    "dest": "/api/index.js"
  },
  {
    "src": "/(.*)",
    "dest": "/frontend/$1"
  },
  {
    "src": "/",
    "dest": "/frontend/index.html"
  }
]
}